{
    "name": "thrubuswp/widgets",
    "description": "WordPress Widgets.",
    "type": "library",
    "license": "Mit",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "keywords": [
        "wordpress",
        "post type"
    ],
    "authors": [
        {
            "name": "vigih dev",
            "email": "vigihdev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/serializer": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "10.5.x-dev"
    },
    "autoload": {
        "psr-4": {
            "ThrubusWP\\Widgets\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ThrubusWP\\Widgets\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "dev": "php -S localhost:4377 local-dev/index.php"
    },
    "config": {
        "process-timeout": 0
    }
}
